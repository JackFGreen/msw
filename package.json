{
  "name": "@jackgreen/msw",
  "version": "0.1.3",
  "description": "Provider switch CLI for Claude Code, Codex, and OpenCode.",
  "type": "module",
  "bin": {
    "msw": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "check:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "dev": "tsx src/cli.ts",
    "lint": "eslint src test",
    "format": "prettier --write src",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "lint-staged": {
    "**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JackFGreen/msw.git"
  },
  "homepage": "https://github.com/JackFGreen/msw",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "comment-json": "^4.2.5",
    "smol-toml": "^1.4.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.14",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^2.1.9"
  }
}
